{
  "name": "shopify-integration-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "shopify app dev",
    "dev:local": "concurrently \"remix watch\" \"node --watch server.js\"",
    "build": "remix build",
    "build:watch": "remix watch",
    "start": "node server.js",
    "setup": "prisma migrate dev && prisma generate",
    "test": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "@remix-run/express": "^2.7.0",
    "@remix-run/node": "^2.7.0",
    "@remix-run/react": "^2.7.0",
    "@remix-run/serve": "^2.7.0",
    "@shopify/app-bridge-react": "^4.2.10",
    "@shopify/polaris": "^12.0.0",
    "@shopify/shopify-app-remix": "^2.5.0",
    "@shopify/shopify-app-session-storage-prisma": "^4.0.0",
    "compression": "^1.7.4",
    "express": "^4.18.2",
    "morgan": "^1.10.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.7.0",
    "@shopify/app": "^3.56.0",
    "@shopify/cli": "^3.56.0",
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.2.0",
    "concurrently": "^8.2.0",
    "prisma": "^5.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
